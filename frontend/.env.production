# Real-auth mode: dashboards call the live backend API for login.
# VITE_MOCK_AUTH must be false so /admin and /sales hit /api/auth/* instead of
# faking a signed-in user. Vite inlines these at build time (production mode).
VITE_MOCK_AUTH=false
# Absolute backend URL the SPA calls. Either keep it here OR set it as a Railway
# service variable on the frontend service (a Railway var overrides this file).
# Replace with your backend service's public domain (no trailing slash):
VITE_API_BASE=https://REPLACE_WITH_BACKEND_DOMAIN.up.railway.app
