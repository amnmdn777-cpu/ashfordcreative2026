{
  "name": "ashford-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --env-file=.env src/index.ts",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "build": "node ./build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push --config packages/db/drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "seed": "tsx --env-file=.env src/scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.49.0",
    "@workspace/api-zod": "file:./packages/api-zod",
    "@workspace/db": "file:./packages/db",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "puppeteer": "^24.42.0",
    "resend": "^4.8.0",
    "satori": "^0.26.0",
    "stripe": "^17.7.0",
    "svix": "^1.91.1",
    "twilio": "^5.13.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
